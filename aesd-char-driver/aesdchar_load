#!/bin/sh
module=aesdchar
device=aesdchar
mode="664"
cd `dirname $0`
set -e
# Group: since distributions do it differently, look for wheel or use staff
if grep -q '^staff:' /etc/group; then
    group="staff"
else
    group="wheel"
fi

if [ -e ${module}.ko ]; then
    echo "Loading local built file ${module}.ko"
    insmod ./$module.ko $* || exit 1
else
    echo "Local file ${module}.ko not found, attempting to modprobe"
    modprobe ${module} || exit 1
fi


# Wait up to 5 seconds for the module to appear in /proc/devices
count=0
while ! grep -q "$module" /proc/devices 2>/dev/null; do
    sleep 0.1
    count=$((count + 1))
    if [ $count -ge 50 ]; then
        echo "Error: $module not found in /proc/devices after 5 seconds"
        exit 1
    fi
done

# Get the major number and create the device node
major=$(awk "\$2==\"$module\" {print \$1}" /proc/devices)
rm -f /dev/${device}
mknod /dev/${device} c $major 0
chgrp $group /dev/${device}
chmod $mode  /dev/${device}
